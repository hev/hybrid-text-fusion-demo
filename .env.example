# Copy to `.env` and fill in. Real environment variables take precedence.

# Base URL of a running Layer gateway (Turbopuffer-compatible API).
LAYER_GATEWAY_URL=http://localhost:8080

# Bearer token the gateway accepts. In the gateway's default deriveFromStore
# auth mode this is your upstream Turbopuffer API key; with minted ApiKeys it
# is the issued key. Leave blank only if the gateway runs in `open` auth mode.
LAYER_API_KEY=

# Namespace the demo writes to and searches.
LAYER_NAMESPACE=scifact-demo

# Field HybridText ranks over. Must be declared full_text_search in the schema
# (ingest.py does this). Leave as `content` unless you know why you're changing it.
LAYER_SEARCH_FIELD=content

# Port for the local search UI.
PORT=8000
